{
  "name": "fastbridge-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:root": "turbo run dev --filter=root",
    "dev:all": "node scripts/dev-all.mjs",
    "build:all": "TURBO_CONCURRENCY=1 turbo run build",
    "clean": "turbo run clean --force",
    "vercel:env": "node scripts/build-vercel-env.mjs",
    "chains:sync": "node scripts/sync-chains.mjs",
    "chain:add": "node scripts/chains-add.mjs",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "precommit:fix-staged": "node scripts/precommit-fix-staged.mjs",
    "prepare": "husky"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "husky": "^9.1.7",
    "turbo": "^2.7.5",
    "typescript": "~5.8.3",
    "ultracite": "7.2.3"
  },
  "dependencies": {
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19"
  }
}
